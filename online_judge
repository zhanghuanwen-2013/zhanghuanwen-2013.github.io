<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>题目页面</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: "Microsoft Yahei", sans-serif; }
        body { padding: 20px; background: #f8f9fa; }
        /* 题目列表：纯静态样式，无hover特效 */
        .problem-list { background: #fff; padding: 15px; border-radius: 6px; max-width: 800px; margin: 0 auto; }
        .problem-list li { list-style: none; margin: 8px 0; }
        .problem-list a { display: block; padding: 6px; text-decoration: none; color: #333; border-radius: 4px; }
        /* 题目详情：纯静态，无装饰性边框/动效 */
        .problem-detail { background: #fff; padding: 20px; border-radius: 6px; max-width: 800px; margin: 0 auto; }
        .problem-detail h1 { font-size: 18px; margin-bottom: 15px; }
        .problem-detail h3 { font-size: 15px; margin: 12px 0 8px; color: #007bff; }
        .problem-detail p { line-height: 1.6; margin: 6px 0; }
        /* 样例框：纯静态，无样式特效 */
        .sample-box { background: #f5f5f5; padding: 8px; border-radius: 4px; margin: 5px 0; font-family: Consolas, monospace; white-space: pre; }
        /* 提示文字：基础样式 */
        .tip { color: #666; margin: 20px auto; text-align: center; max-width: 800px; }
        .tip a { color: #007bff; text-decoration: none; }
        /* KaTeX基础样式：解决渲染对齐、溢出问题，无特效 */
        .katex { vertical-align: middle; font-size: 1em; }
        .katex-display { margin: 0.5em 0; }
        .latex-content { word-wrap: break-word; overflow-wrap: break-word; }
    </style>
    <!-- 替换为KaTeX官方国内稳定CDN，包含核心+自动渲染，解决加载/解析问题 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" integrity="sha256-V8SV2MO1FUb63Bwht5Wx9x6PVHNa02gv8BgH/uH3ung=" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.js" integrity="sha256-PxDBWtLj4ML+UzIl/aAb0dFdUu5BzVvfQC2fF7llF2Q=" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/contrib/auto-render.min.js" integrity="sha256-+XBljXPPiv+OzfbB3cVmLHf4hdUFHlWNZN5spNQ7rmU=" crossorigin="anonymous"></script>
</head>
<body>
<div id="app-container"></div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // 初始化KaTeX自动渲染（官方推荐方式，解决手动匹配$符的解析bug）
        function initLatexRender() {
            renderMathInElement(document.body, {
                delimiters: [
                    { left: '$', right: '$', display: false }, // 行内公式 $xxx$
                    { left: '$$', right: '$$', display: true } // 块级公式（可选保留）
                ],
                throwOnError: false, // 语法错误不崩溃，显示原公式
                strict: "ignore",    // 宽松解析，兼容非标准LaTeX
                trust: true,         // 允许所有LaTeX命令，解决符号识别失败
                maxSize: Infinity    // 取消公式大小限制
            });
        }

        // 获取URL参数，判断渲染列表/详情
        const searchParams = new URLSearchParams(window.location.search);
        const id = searchParams.get("id") || "list";
        const appContainer = document.getElementById('app-container');

        // 题目数据：修复LaTeX反斜杠为**双重\\**（JS解析后为\，KaTeX正常识别）
        const problemList = [
            {
                id: 1,
                name: "A + B Problem",
                desc: "给定两个整数 $a$ 和 $b$，求它们的和 $S = a + b$。数据范围：$a, b \\in [-10^3, 10^3]$，且 $a > 0$。",
                input: "输入一行，包含两个整数 $a$ 和 $b$，空格分隔（$a < 1000$）。",
                output: "输出一行，包含一个整数，表示 $a + b$ 的结果。",
                samples: [
                    { in: "1 2", out: "3" },
                    { in: "-5 8", out: "3" }
                ]
            },
            {
                id: 2,
                name: "求一元二次方程的根",
                desc: "求解一元二次方程 $ax^2 + bx + c = 0$ 的实数根（$a \\neq 0$）。先计算判别式 $\\Delta = b^2 - 4ac$：1. $\\Delta > 0$ 输出两个根 $x_1=\\frac{-b+\\sqrt{\\Delta}}{2a}$、$x_2=\\frac{-b-\\sqrt{\\Delta}}{2a}$；2. $\\Delta = 0$ 输出一个根 $x = -\\frac{b}{2a}$；3. $\\Delta < 0$ 输出无实数根。数据范围：$a,b,c \\in [-100,100]$。",
                input: "输入一行，包含三个整数 $a,b,c$，空格分隔。",
                output: "根保留2位小数；无实数根输出 No real roots。",
                samples: [
                    { in: "1 -3 2", out: "2.00 1.00" },
                    { in: "1 2 1", out: "-1.00" },
                    { in: "1 0 1", out: "No real roots" }
                ]
            }
        ];

        // 核心渲染逻辑：纯静态，无特效
        if (id === "list") {
            // 渲染题目列表
            appContainer.innerHTML = `
                <ul class="problem-list">
                    ${problemList.map(p => `<li><a href="?id=${p.id}">${p.id} - ${p.name}</a></li>`).join('')}
                </ul>
            `;
        } else if (!isNaN(Number(id))) {
            // 渲染题目详情
            const problemId = Number(id);
            const problem = problemList.find(p => p.id === problemId);
            if (problem) {
                // 拼接样例HTML
                const samplesHtml = problem.samples.map((s, i) => `
                    <p><b>样例 ${i+1} 输入</b></p>
                    <div class="sample-box">${s.in}</div>
                    <p><b>样例 ${i+1} 输出</b></p>
                    <div class="sample-box">${s.out}</div>
                `).join('');
                // 拼接详情HTML（公式区域保留latex-content类做溢出处理）
                appContainer.innerHTML = `
                    <div class="problem-detail">
                        <h1>${problem.id} - ${problem.name}</h1>
                        <h3>题目描述</h3>
                        <p class="latex-content">${problem.desc}</p>
                        <h3>输入格式</h3>
                        <p class="latex-content">${problem.input}</p>
                        <h3>输出格式</h3>
                        <p class="latex-content">${problem.output}</p>
                        <h3>样例</h3>
                        ${samplesHtml}
                    </div>
                `;
                // 执行KaTeX自动渲染
                initLatexRender();
            } else {
                // 题目不存在提示
                appContainer.innerHTML = `<p class="tip">暂无题目 ${id} → <a href="?id=list">返回题目列表</a></p>`;
            }
        } else if (id === "") {
            // 非法参数跳转到列表页
            window.location.href = window.location.pathname + "?id=list";
        } else {
            appContainer.innerHTML = `Error! 请检查参数`;
        }
    });
</script>
</body>
</html>
